<Window x:Class="LiveReplay.Views.PlaybackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:LiveReplay.Views.Controls"
        Title="LiveReplay" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#262526">

    <Grid x:Name="MainGrid">
        <!-- 背景图片 -->
        <Image x:Name="BackgroundImage" Stretch="UniformToFill"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部工具栏 -->
            <Border Grid.Row="0" Background="Transparent" Padding="10,8">
                <TextBlock x:Name="TitleText" Text="直播回放" FontSize="16"
                           Foreground="White" VerticalAlignment="Center"/>
            </Border>

            <!-- 主内容区域 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="2*" MinWidth="400"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="200"/>
                </Grid.ColumnDefinitions>

                <!-- 弹幕区+礼物区 -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 时间显示 -->
                    <Border Grid.Row="0" CornerRadius="4" Padding="10,8" HorizontalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="White" Opacity="0.2"/>
                        </Border.Background>
                        <TextBlock x:Name="CurrentTimeText" Text="00:00:00" FontSize="18"
                                   FontWeight="Bold" Foreground="#555"/>
                    </Border>

                    <!-- 弹幕区 -->
                    <Border Grid.Row="1" Background="Transparent" Margin="2">
                        <ItemsControl ItemsSource="{Binding VisibleDanmaku}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:DanmakuCard/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="#3D3D3D" Opacity="0.1"/>

                    <!-- 礼物区 -->
                    <Border Grid.Row="3" Background="Transparent" Margin="2">
                        <ItemsControl ItemsSource="{Binding VisibleGift}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:GiftCard/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </Grid>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center"
                              VerticalAlignment="Stretch" Background="#3D3D3D" Opacity="0.1"/>

                <!-- 视频区 -->
                <Grid Grid.Column="2" Margin="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0">
                        <Grid>
                            <!-- 视频区背景图片 (透明，透出页面背景) -->
                            <Image x:Name="VideoBackgroundImage" Stretch="UniformToFill"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0"/>
                            <ContentControl x:Name="VideoControl"/>
                        </Grid>
                    </Border>

                    <!-- 播放控制栏 -->
                    <Border Grid.Row="1" Padding="10">
                        <Border.Background>
                            <SolidColorBrush Color="#2D2D2D" Opacity="0.5"/>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" x:Name="PlayPauseButton"
                                    Click="PlayPause_Click"
                                    Content="&#xE768;" FontFamily="Segoe MDL2 Assets"
                                    Background="Transparent" Foreground="White"
                                    BorderThickness="0" FontSize="20" Cursor="Hand"
                                    Width="40" Height="40"/>

                            <Slider Grid.Column="1" x:Name="ProgressSlider"
                                    VerticalAlignment="Center" Margin="10,0"
                                    Minimum="0" Maximum="100"
                                    ValueChanged="ProgressSlider_ValueChanged"
                                    PreviewMouseDown="ProgressSlider_PreviewMouseDown"
                                    PreviewMouseUp="ProgressSlider_PreviewMouseUp"/>

                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Content="&#xE767;" FontFamily="Segoe MDL2 Assets"
                                        Background="Transparent" Foreground="White"
                                        BorderThickness="0" FontSize="16" Cursor="Hand"
                                        Width="30" Height="30"/>
                                <Slider x:Name="VolumeSlider" Width="80" VerticalAlignment="Center"
                                        Minimum="0" Maximum="100" Value="100"
                                        ValueChanged="VolumeSlider_ValueChanged"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Center"
                              VerticalAlignment="Stretch" Background="#3D3D3D" Opacity="0.1"/>

                <!-- SC区 -->
                <Border Grid.Column="4" Background="Transparent" Margin="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding VisibleSc}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:ScCard/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>