<Page x:Class="LiveReplay.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720" d:DesignWidth="1200"
      Title="设置"
      Background="#1E1E1E">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="设置" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,30"/>

        <!-- 设置内容 -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Width="600">
                <!-- 基准字号设置 -->
                <Border Background="#2D2D2D" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="基准字号" Foreground="#CCC" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Slider x:Name="FontSizeSlider" Width="150"
                                    Minimum="10" Maximum="40" Value="14"
                                    ValueChanged="FontSizeSlider_ValueChanged"/>
                            <TextBlock x:Name="FontSizeText" Text="14"
                                       Foreground="#CCC" Width="30" TextAlignment="Center"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 背景图片设置 -->
                <Border Background="#2D2D2D" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock Text="背景图片" Foreground="#CCC" VerticalAlignment="Center"/>
                            <TextBlock x:Name="BackgroundPathText" Text="未选择" Foreground="#888"
                                       FontSize="12" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="选择图片"
                                    Click="SelectBackground_Click"
                                    Background="#3D3D3D" Foreground="White"
                                    BorderThickness="0" Padding="15,8" Cursor="Hand" Margin="0,0,10,0"/>
                            <Button Content="清除"
                                    Click="ClearBackground_Click"
                                    Background="#444" Foreground="#AAA"
                                    BorderThickness="0" Padding="15,8" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 礼物最低价格设置 -->
                <Border Background="#2D2D2D" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="礼物最低显示价格(元)" Foreground="#CCC" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBox x:Name="MinPriceTextBox" Width="80"
                                     Text="0" TextAlignment="Center"
                                     Background="#1E1E1E" Foreground="#CCC"
                                     BorderBrush="#444" BorderThickness="1"
                                     Padding="5" VerticalContentAlignment="Center"
                                     TextChanged="MinPriceTextBox_TextChanged"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 时间字体设置 -->
                <Border Background="#2D2D2D" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="时间字体设置" Foreground="#CCC" FontWeight="Bold" Margin="0,0,0,15"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="字体：" Foreground="#AAA" VerticalAlignment="Center" Width="60"/>
                            <ComboBox x:Name="TimeFontComboBox" Grid.Column="1"
                                      Background="#1E1E1E" Foreground="Black"
                                      BorderBrush="#444" Padding="8,5"
                                      SelectionChanged="TimeFontComboBox_SelectionChanged">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="颜色：" Foreground="#AAA" VerticalAlignment="Center" Width="60"/>
                            <TextBox x:Name="TimeColorTextBox" Grid.Column="1"
                                     Text="#555555" Width="80"
                                     Background="#1E1E1E" Foreground="#CCC"
                                     BorderBrush="#444" BorderThickness="1"
                                     Padding="5" VerticalContentAlignment="Center"
                                     TextChanged="TimeColorTextBox_TextChanged"/>
                            <Border x:Name="TimeColorPreview" Grid.Column="2" Width="24" Height="24"
                                    Background="#555555" CornerRadius="4" Margin="10,0,0,0"
                                    VerticalAlignment="Center"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="大小：" Foreground="#AAA" VerticalAlignment="Center" Width="60"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Slider x:Name="TimeFontSizeSlider" Width="150"
                                        Minimum="10" Maximum="40" Value="18"
                                        ValueChanged="TimeFontSizeSlider_ValueChanged"/>
                                <TextBlock x:Name="TimeFontSizeText" Text="18"
                                           Foreground="#CCC" Width="30" TextAlignment="Center"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 用户名字体设置 -->
                <Border Background="#2D2D2D" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="用户名字体设置" Foreground="#CCC" FontWeight="Bold" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="字体：" Foreground="#AAA" VerticalAlignment="Center" Width="60"/>
                            <ComboBox x:Name="UserNameFontComboBox" Grid.Column="1"
                                      Background="#1E1E1E" Foreground="Black"
                                      BorderBrush="#444" Padding="8,5"
                                      SelectionChanged="UserNameFontComboBox_SelectionChanged">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 弹幕字体设置 -->
                <Border Background="#2D2D2D" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="弹幕字体设置" Foreground="#CCC" FontWeight="Bold" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="字体：" Foreground="#AAA" VerticalAlignment="Center" Width="60"/>
                            <ComboBox x:Name="DanmakuFontComboBox" Grid.Column="1"
                                      Background="#1E1E1E" Foreground="Black"
                                      BorderBrush="#444" Padding="8,5"
                                      SelectionChanged="DanmakuFontComboBox_SelectionChanged">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- SC内容字体设置 -->
                <Border Background="#2D2D2D" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="SC内容字体设置" Foreground="#CCC" FontWeight="Bold" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="字体：" Foreground="#AAA" VerticalAlignment="Center" Width="60"/>
                            <ComboBox x:Name="ScContentFontComboBox" Grid.Column="1"
                                      Background="#1E1E1E" Foreground="Black"
                                      BorderBrush="#444" Padding="8,5"
                                      SelectionChanged="ScContentFontComboBox_SelectionChanged">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 保存按钮 -->
                <Button Content="保存设置"
                        Click="SaveSettings_Click"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Left"
                        Margin="0,20,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>