<Page x:Class="LiveReplay.Views.ReplayPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:LiveReplay.Views"
      mc:Ignorable="d"
      d:DesignHeight="720" d:DesignWidth="1200"
      Title="回放"
      Background="#1E1E1E">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="直播回放" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,30"/>

        <!-- 内容区域 -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="500">
            <!-- 视频文件选择 -->
            <Border Background="#2D2D2D" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="视频文件" VerticalAlignment="Center" Foreground="#AAA" Width="80"/>
                    <TextBox Grid.Column="1" x:Name="VideoPathTextBox"
                             Text="{Binding VideoPath, Mode=OneWay}"
                             IsReadOnly="True"
                             Background="#1E1E1E" Foreground="#CCC"
                             BorderBrush="#444" BorderThickness="1"
                             Padding="10,8" Margin="10,0"
                             VerticalContentAlignment="Center"/>
                    <Button Grid.Column="2" Content="选择"
                            Click="SelectVideo_Click"
                            Background="#3D3D3D" Foreground="White"
                            BorderThickness="0" Padding="15,8" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- 弹幕文件选择 -->
            <Border Background="#2D2D2D" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="弹幕文件" VerticalAlignment="Center" Foreground="#AAA" Width="80"/>
                    <TextBox Grid.Column="1" x:Name="XmlPathTextBox"
                             Text="{Binding XmlPath, Mode=OneWay}"
                             IsReadOnly="True"
                             Background="#1E1E1E" Foreground="#CCC"
                             BorderBrush="#444" BorderThickness="1"
                             Padding="10,8" Margin="10,0"
                             VerticalContentAlignment="Center"/>
                    <Button Grid.Column="2" Content="选择"
                            Click="SelectXml_Click"
                            Background="#3D3D3D" Foreground="White"
                            BorderThickness="0" Padding="15,8" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- 开始按钮 -->
            <Button Content="开始播放"
                    Click="StartPlayback_Click"
                    IsEnabled="{Binding CanStart}"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0"
                    Width="200" Height="45"
                    FontSize="16"/>
        </StackPanel>
    </Grid>
</Page>