<Page x:Class="LiveReplay.Views.PreviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:LiveReplay.Views.Controls"
      mc:Ignorable="d"
      d:DesignHeight="720" d:DesignWidth="1280"
      Title="预览"
      Background="#262526">

    <Grid x:Name="MainGrid">
        <!-- 背景图片 -->
        <Image x:Name="BackgroundImage" Stretch="UniformToFill"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部工具栏 -->
            <Border Grid.Row="0" Background="Transparent" Padding="10,8">
                <TextBlock Text="预览模式" FontSize="16"
                           Foreground="White" VerticalAlignment="Center"/>
            </Border>

            <!-- 主内容区域 - 与播放窗口布局一致 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="2*" MinWidth="400"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="200"/>
                </Grid.ColumnDefinitions>

                <!-- 弹幕区+礼物区 -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 时间显示 -->
                    <Border Grid.Row="0" CornerRadius="4" Padding="10,8" HorizontalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="White" Opacity="0.2"/>
                        </Border.Background>
                        <TextBlock x:Name="CurrentTimeText" Text="00:00:00" FontSize="18" FontWeight="Bold" Foreground="#555"/>
                    </Border>

                    <!-- 弹幕区 -->
                    <Border Grid.Row="1" Background="Transparent" Margin="2">
                        <ItemsControl ItemsSource="{Binding PreviewDanmaku}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:DanmakuCard/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="#3D3D3D" Opacity="0.1"/>

                    <!-- 礼物区 -->
                    <Border Grid.Row="3" Background="Transparent" Margin="2">
                        <ItemsControl ItemsSource="{Binding FilteredGifts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:GiftCard/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </Grid>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center"
                              VerticalAlignment="Stretch" Background="#3D3D3D" Opacity="0.1"/>

                <!-- 中间：视频区预览 -->
                <Border Grid.Column="2" Margin="2">
                    <Grid>
                        <!-- 视频区背景图片 (透明，透出页面背景) -->
                        <Image x:Name="VideoBackgroundImage" Stretch="UniformToFill"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="视频区域" FontSize="20" Foreground="#666"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- 播放控制栏预览 -->
                        <Border Grid.Row="1" Padding="10">
                            <Border.Background>
                                <SolidColorBrush Color="#2D2D2D" Opacity="0.5"/>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Content="&#xE768;" FontFamily="Segoe MDL2 Assets"
                                        Background="Transparent" Foreground="White"
                                        BorderThickness="0" FontSize="20" Cursor="Hand"
                                        Width="40" Height="40" IsHitTestVisible="False"/>

                                <Slider Grid.Column="1" VerticalAlignment="Center" Margin="10,0"
                                        Minimum="0" Maximum="100" Value="30" IsHitTestVisible="False"/>

                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <Button Content="&#xE767;" FontFamily="Segoe MDL2 Assets"
                                            Background="Transparent" Foreground="White"
                                            BorderThickness="0" FontSize="16"
                                            Width="30" Height="30" IsHitTestVisible="False"/>
                                    <Slider Width="80" VerticalAlignment="Center"
                                            Minimum="0" Maximum="100" Value="100" IsHitTestVisible="False"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

                <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Center"
                              VerticalAlignment="Stretch" Background="#3D3D3D" Opacity="0.1"/>

                <!-- SC区预览 -->
                <Border Grid.Column="4" Background="Transparent" Margin="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PreviewSc}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:ScCard/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>