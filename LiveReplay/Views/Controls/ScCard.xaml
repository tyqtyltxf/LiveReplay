<UserControl x:Class="LiveReplay.Views.Controls.ScCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="100" d:DesignWidth="280"
             MouseLeftButtonDown="ScCard_MouseLeftButtonDown"
             Opacity="0" RenderTransformOrigin="0.5,0.5">
    <UserControl.RenderTransform>
        <TranslateTransform X="20"/>
    </UserControl.RenderTransform>
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="20" To="0" Duration="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Border x:Name="CardBorder" CornerRadius="8" Margin="6,3" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 上部分：用户信息区 -->
            <Border Grid.Row="0" Background="#EDF5FF" Padding="10,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 头像 -->
                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                            Background="#DDD" Margin="0,0,10,0">
                        <Border.Clip>
                            <EllipseGeometry Center="18,18" RadiusX="18" RadiusY="18"/>
                        </Border.Clip>
                        <Image x:Name="AvatarImage" Stretch="UniformToFill"/>
                    </Border>

                    <!-- 用户名和价格 -->
                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="UserNameText" Grid.Row="0" Text="{Binding UserName}"
                                   FontSize="13" Foreground="#333" FontWeight="Medium"/>
                        <TextBlock x:Name="PriceText" Grid.Row="1" Foreground="#333" FontSize="12" Margin="0,2,0,0">
                            <Run Text="CN￥"/>
                            <Run Text="{Binding Price}"/>
                        </TextBlock>
                    </Grid>

                    <!-- 相对时间（右下角） -->
                    <TextBlock x:Name="TimeText" Grid.Column="2" Text="{Binding RelativeTimeText}"
                               FontSize="11" Foreground="#999"
                               VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- 下部分：SC内容区 -->
            <Border Grid.Row="1" Background="{Binding BackgroundColor}" Padding="10,8">
                <TextBlock x:Name="ContentText" Text="{Binding Content}"
                           FontSize="13" Foreground="White" TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </Border>
</UserControl>